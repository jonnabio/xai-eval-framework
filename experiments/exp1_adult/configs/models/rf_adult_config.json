{
    "model": {
        "type": "RandomForest",
        "params": {
            "n_estimators": 200,
            "max_depth": null,
            "min_samples_split": 2,
            "min_samples_leaf": 1,
            "max_features": "sqrt",
            "bootstrap": true,
            "n_jobs": -1,
            "random_state": 42,
            "class_weight": "balanced_subsample",
            "verbose": 0
        }
    },
    "training": {
        "test_size": 0.2,
        "random_state": 42
    },
    "output": {
        "model_dir": "experiments/exp1_adult/models",
        "results_dir": "experiments/exp1_adult/results",
        "model_filename": "rf_model.pkl",
        "metrics_filename": "rf_metrics.json"
    },
    "validation": {
        "min_accuracy": 0.80,
        "min_roc_auc": 0.85
    }
}